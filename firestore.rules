rules_version = '2';

// ============================================================
//  Firestore Security Rules — Casa Verde Canas
//  Proyecto: casaverdecanas-199
//
//  ACTUALIZAR EN: Firebase Console → Firestore → Reglas
//  VERSIONAR EN:  GitHub repo raíz como firestore.rules
//
//  Última revisión: Mayo 2026 — agregada espacios_comunes
// ============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ── SITIO PÚBLICO — lectura libre, escritura autenticada ──
    //    Estas colecciones las leen index.html y cabana.html
    //    sin que el visitante tenga sesión iniciada.

    match /cabanas/{doc} {
      allow read:  if true;
      allow write: if request.auth != null;
    }

    match /disponibilidad/{doc} {
      allow read:  if true;
      allow write: if request.auth != null;
    }

    match /espacios_comunes/{doc} {
      allow read:  if true;
      allow write: if request.auth != null;
    }

    // ── MANUAL DEL SISTEMA — usuarios autenticados ────────────
    match /config/manual {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── TODO LO DEMÁS — solo autenticados ────────────────────
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

  }
}